{
  "name": "factoryfloor-website",
  "private": true,
  "scripts": {
    "css:build": "bunx @tailwindcss/cli -i css/input.css -o assets/css/style.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i css/input.css -o assets/css/style.css --watch",
    "assets": "bun run css:build",
    "build": "bun run assets && hugo",
    "dev": "bun run assets && hugo serve --disableFastRender --gc"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1"
  }
}
