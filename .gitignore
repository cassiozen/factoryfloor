# Generated Xcode project and Info.plist (regenerate with `xcodegen`)
*.xcodeproj
*.xcworkspace
FactoryFloor/Info.plist

# SourceKit-LSP build server config (generated per-worktree with absolute paths)
buildServer.json

# Xcode build artifacts
build/
DerivedData/
*.xcuserdata

# Ghostty build output (rebuild with `zig build`)
ghostty/zig-out/
ghostty/.zig-cache/

# Monaco editor build output (rebuild with scripts/build-editor.sh)
Resources/MonacoEditor/

# Node dependencies
node_modules/
editor/node_modules/

# Python
__pycache__/

# macOS
.DS_Store
*.swp
*~

# Ghostty xcframework is built from submodule, not committed
# ghostty/macos/GhosttyKit.xcframework is generated by zig build
default.profraw
